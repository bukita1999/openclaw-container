#
# Copy this directory to instances/<bot-name>/, then rename this file to .env.
# After copying, update every path that still contains "_template".
# INSTANCE_ENV_FILE must point to this instance's own .env file.
#
INSTANCE_ENV_FILE=./instances/_template/.env

IMAGE_NAME=openclaw-debian:local
CONTAINER_NAME=openclaw-template
OPENCLAW_CONTAINER_HOSTNAME=openclaw-template

BUILD_TARGET=openclaw-runtime
NODE_MAJOR=22
OPENCLAW_VERSION=latest
PYTHON_VERSION=3.12
INSTALL_CHROMIUM=1
INSTALL_VNC=0
INSTALL_GO=0
GO_VERSION=1.26.1
USE_SJTUG_MIRROR=0

USER_UID=1000
USER_GID=1000
TZ=Asia/Shanghai

OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

OPENCLAW_CONFIG_DIR=./instances/_template/openclaw
OPENCLAW_WORKSPACE_DIR=./instances/_template/workspace
UV_CACHE_DIR_HOST=./instances/_template/uv-cache
UV_PYTHON_DIR_HOST=./instances/_template/uv-python
GO_PATH_HOST=./instances/_template/go
CHROMIUM_PROFILE_DIR_HOST=./instances/_template/chromium-profile

SHM_SIZE=2gb
DISPLAY=:99

ENABLE_VNC=0
START_CHROMIUM=1
OPENCLAW_BROWSER_AUTOSTART=0
OPENCLAW_BROWSER_AUTOSTART_WAIT_SECONDS=60
VNC_PORT=5900
NOVNC_PORT=6080
VNC_PASSWORD=openclaw
VNC_RESOLUTION=1440x900x24
CHROMIUM_URL=about:blank
CHROMIUM_HEADLESS=0
CHROMIUM_EXTRA_ARGS=
CHROMIUM_REMOTE_DEBUGGING_PORT=9222

HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=127.0.0.1,localhost
NODE_USE_ENV_PROXY=1

OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
BAILIAN_API_KEY=
