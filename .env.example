IMAGE_NAME=openclaw-ubuntu:local
CONTAINER_NAME=openclaw
OPENCLAW_CONTAINER_HOSTNAME=openclaw

NODE_MAJOR=22
OPENCLAW_VERSION=latest
PYTHON_VERSION=3.12
INSTALL_CHROMIUM=0
INSTALL_VNC=0
INSTALL_GO=0
GO_VERSION=1.26.1

USER_UID=1000
USER_GID=1000
TZ=Asia/Shanghai

OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

OPENCLAW_CONFIG_DIR=./data/openclaw
OPENCLAW_WORKSPACE_DIR=./data/workspace
UV_CACHE_DIR_HOST=./data/uv-cache
UV_PYTHON_DIR_HOST=./data/uv-python
GO_PATH_HOST=./data/go
PLAYWRIGHT_CACHE_HOST=./data/playwright

SHM_SIZE=2gb
DISPLAY=:99

ENABLE_VNC=0
START_CHROMIUM=0
VNC_PORT=5900
NOVNC_PORT=6080
VNC_PASSWORD=openclaw
VNC_RESOLUTION=1440x900x24
CHROMIUM_URL=https://openclaw.ai/
CHROMIUM_REMOTE_DEBUGGING_PORT=9222

HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=127.0.0.1,localhost

# Optional provider/session variables can also live in .env because the compose
# service loads the file directly into the container runtime.
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
BAILIAN_API_KEY=
