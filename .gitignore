.env
data/openclaw/*
data/workspace/*
data/uv-cache/*
data/uv-python/*
data/go/*
data/chromium-profile/*
data/playwright/*
# Ignore all per-bot instances; keep only the shared template in Git.
instances/*
!data/openclaw/.gitkeep
!data/openclaw/openclaw.json.example
!data/workspace/.gitkeep
!data/uv-cache/.gitkeep
!data/uv-python/.gitkeep
!data/go/.gitkeep
!data/chromium-profile/.gitkeep
!instances/.gitkeep
!instances/_template/
!instances/_template/**
